RewriteEngine On
RewriteBase /

# API・Sanctumリクエストを api/index.php（Laravel）に転送
RewriteCond %{REQUEST_URI} ^/(api|sanctum)(/|$)
RewriteRule ^ api/index.php [L]

# 実在するファイル・ディレクトリはそのまま
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 公開動的ルート
RewriteRule ^blog/([^/]+)/$ /blog/_/index.html [L]
RewriteRule ^podcast/([^/]+)/$ /podcast/_/index.html [L]

# トレイリングスラッシュなしの公開ルートをリダイレクト
RewriteRule ^blog/([^/]+)$ /blog/$1/ [R=301,L]
RewriteRule ^podcast/([^/]+)$ /podcast/$1/ [R=301,L]

# 会員動的ルート: 実IDへのアクセスをプレースホルダーのシェルで処理
# ブラウザのURLは変わらないのでuseParams()は正しいIDを取得できる
RewriteRule ^members/lessons/([^/]+)/$ /members/lessons/_/index.html [L]
RewriteRule ^members/podcast/([^/]+)/$ /members/podcast/_/index.html [L]
RewriteRule ^members/blog/([^/]+)/$ /members/blog/_/index.html [L]

# トレイリングスラッシュなしのアクセスはスラッシュ付きにリダイレクト
RewriteRule ^members/lessons/([^/]+)$ /members/lessons/$1/ [R=301,L]
RewriteRule ^members/podcast/([^/]+)$ /members/podcast/$1/ [R=301,L]
RewriteRule ^members/blog/([^/]+)$ /members/blog/$1/ [R=301,L]
